<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="@drawable/btn_light"
                android:contentDescription="Back"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/tv_level_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Level 1"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"/>

            <LinearLayout
                android:id="@+id/wall_dots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/tv_walls_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 walls left"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:id="@+id/dot_indicators"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"/>

            <ImageButton
                android:id="@+id/btn_reset"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_rotate"
                android:background="@drawable/btn_light"
                android:contentDescription="Reset"
                android:layout_marginEnd="8dp"
                android:visibility="gone"/>

            <ImageButton
                android:id="@+id/btn_play"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_play_triangle"
                android:background="@drawable/btn_dark_circle"
                android:contentDescription="Release dots"
                android:padding="12dp"/>
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider"/>

    <!-- Game canvas -->
    <com.justmakeapps.gravitydots.ui.game.GameView
        android:id="@+id/game_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg_canvas"/>

    <!-- Banner ad -->
    <FrameLayout
        android:id="@+id/banner_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_surface"/>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/dialog_bg"
    android:padding="24dp" android:layout_marginHorizontal="16dp">

    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_gravity="center"
        android:layout_marginBottom="14dp">
        <ImageView android:id="@+id/star1" android:layout_width="28dp" android:layout_height="28dp"
            android:src="@drawable/ic_star" android:layout_marginEnd="6dp"/>
        <ImageView android:id="@+id/star2" android:layout_width="36dp" android:layout_height="36dp"
            android:src="@drawable/ic_star" android:layout_marginEnd="6dp"/>
        <ImageView android:id="@+id/star3" android:layout_width="28dp" android:layout_height="28dp"
            android:src="@drawable/ic_star"/>
    </LinearLayout>

    <TextView android:id="@+id/tv_complete_title"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Level done!" android:textSize="22sp" android:textStyle="bold"
        android:textColor="@color/text_primary" android:layout_gravity="center"
        android:layout_marginBottom="4dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/card_purple" android:padding="12dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginVertical="16dp">
        <View android:layout_width="28dp" android:layout_height="28dp"
            android:background="@drawable/btn_dark_circle" android:layout_marginEnd="12dp"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Watch ad — get 3 bonus walls"
                android:textColor="@color/purple_dark" android:textSize="12sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="saved for any level"
                android:textColor="@color/purple" android:textSize="10sp"/>
        </LinearLayout>
        <Button android:id="@+id/btn_watch_ad"
            android:layout_width="wrap_content" android:layout_height="34dp"
            android:text="watch" android:textColor="@color/white"
            android:background="@drawable/btn_dark" android:textSize="11sp"
            android:paddingHorizontal="12dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btn_retry_complete"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:text="retry" android:textColor="@color/text_primary"
            android:background="@drawable/btn_light" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btn_next"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:text="next level" android:textColor="@color/white"
            android:background="@drawable/btn_dark"/>
    </LinearLayout>
</LinearLayout>

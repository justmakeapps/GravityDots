<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/dialog_bg"
    android:padding="24dp" android:layout_marginHorizontal="16dp">

    <View android:layout_width="48dp" android:layout_height="48dp"
        android:background="@drawable/bg_circle_light"
        android:layout_gravity="center" android:layout_marginBottom="14dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="No walls left" android:textSize="22sp" android:textStyle="bold"
        android:textColor="@color/text_primary" android:layout_gravity="center"
        android:layout_marginBottom="8dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="You used all your walls.\nWatch a short ad to get 2 more."
        android:textSize="13sp" android:textColor="@color/text_secondary"
        android:layout_gravity="center" android:gravity="center"
        android:layout_marginBottom="22dp"/>

    <Button android:id="@+id/btn_watch_ad_walls"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="watch ad — get 2 walls"
        android:textColor="@color/white" android:textSize="14sp"
        android:background="@drawable/btn_dark" android:layout_marginBottom="10dp"/>

    <Button android:id="@+id/btn_restart_walls"
        android:layout_width="match_parent" android:layout_height="46dp"
        android:text="restart level"
        android:textColor="@color/text_secondary" android:textSize="13sp"
        android:background="@drawable/btn_light"/>
</LinearLayout>
